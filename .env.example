# Builder's Knowledge Garden — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# This file documents every env var the codebase reads.
# Real values live in Vercel (Production) or .env.local (dev).
# .env*.local is gitignored — never commit real secrets.
# If you push real values here, GitHub's secret scanning will block you.
#
# To set up locally:
#   1. cp .env.example .env.local
#   2. Fill in real values
#   3. npm run dev
#
# To set up Vercel:
#   Dashboard → Project Settings → Environment Variables → add each
#   for Production + Preview + Development.

# ─────────────────────────────────────────────────────────────────────
# Supabase (required for everything that persists)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://YOUR_PROJECT.supabase.co          # server-side alias for NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=eyJ...                       # server-only — never expose to client

# ─────────────────────────────────────────────────────────────────────
# Anthropic (Claude API — drives every AI specialist)
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────────────────────────────
# Twilio (Brief 2 — SMS inbound/outbound)
# ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # ROTATE if it's ever leaked
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX                       # E.164 format, no spaces or dashes

# ─────────────────────────────────────────────────────────────────────
# Clerk (auth — phased in post-MVP)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ─────────────────────────────────────────────────────────────────────
# Stripe (billing — phased in post-MVP)
# ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────
# Replicate (FLUX image generation, Worldwalker)
# ─────────────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...

# ─────────────────────────────────────────────────────────────────────
# Brave Search (q11 Supply Ordering ResourceBroker fallback)
# ─────────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...

# ─────────────────────────────────────────────────────────────────────
# Cron auth (Brief 2 outbound flush + future scheduled tasks)
# ─────────────────────────────────────────────────────────────────────
CRON_SECRET=                                           # openssl rand -hex 32 → 64-char hex string
